{
  "name": "cobra-studio-pet-adoption",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "api": "npm run start:dev --workspace=apps/api",
    "web": "npm run dev --workspace=apps/web",
    "dev": "concurrently \"npm run api\" \"npm run web\"",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "test": "npm run test --workspace=apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
